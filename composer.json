{
    "name": "bazuka/filament-address",
    "description": "A Filament plugin for Danish address autocomplete",
    "keywords": [
        "filament",
        "laravel",
        "address",
        "danish-addresses"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Thor Nissen",
            "email": "thor@bazuka.dk"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "pestphp/pest": "^2.0 || ^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Bazuka\\FilamentAddress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bazuka\\FilamentAddress\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bazuka\\FilamentAddress\\FilamentAddressServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
