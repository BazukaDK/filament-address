{
    "name": "bazuka/filament-dawa",
    "description": "A Filament plugin for the DAWA (Danmarks Adressers Web API) API",
    "keywords": [
        "filament",
        "laravel",
        "dawa",
        "danish-addresses"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Thor Nissen",
            "email": "thor@bazuka.dk"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0 || ^4.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "pestphp/pest": "^2.0 || ^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^2.0 || ^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Bazuka\\FilamentDawa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bazuka\\FilamentDawa\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bazuka\\FilamentDawa\\FilamentDawaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
